<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Assistant</string>
    <key>CFBundleDisplayName</key>
    <string>Assistant</string>
    <key>CFBundleIdentifier</key>
    <string>com.assistant.app</string>
    <key>CFBundleExecutable</key>
    <string>Assistant</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.2</string>
    <!-- accessory: живём в menu bar, без иконки в Dock -->
    <key>LSUIElement</key>
    <true/>
    <!-- без этой строки доступ к микрофону падает -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Нужен для распознавания речи с микрофона.</string>
    <!-- захват системного звука (Core Audio process tap) -->
    <key>NSAudioCaptureUsageDescription</key>
    <string>Нужен для распознавания речи собеседника из системного звука.</string>
</dict>
</plist>
